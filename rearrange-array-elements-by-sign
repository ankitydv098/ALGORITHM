//https://leetcode.com/problems/rearrange-array-elements-by-sign
class Solution {
    public int[] rearrangeArray(int[] nums) {
        int n = nums.length;
        int[] result = new int[n];

        int p = 0;
        int np = 1;

        for (int num : nums) {
            if (num > 0) {
                result[p] = num;
                p += 2;
            } else {
                result[np] = num;
                np += 2;
            }
        }
        return result;
    }
}
