class Node {
    int data;
    Node next;
    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

class SinglyLinkedList {
    Node head;

    void printList() {
        Node current = head;
        while (current != null) {
            System.out.println(current.data);
            current = current.next;
        }
        System.out.println("null");
    }
}

// Yeh hamara main class hai - yahin se program start hoga
public class Main {
    public static void main(String[] args) {
        SinglyLinkedList list = new SinglyLinkedList();

        // Manually 3 nodes banaye aur connect kiye
        Node first = new Node(10);
        Node second = new Node(20);
        Node third = new Node(30);

        list.head = first;       // head pehle node ko point karega
        first.next = second;     // first -> second
        second.next = third;     // second -> third
        // third.next pehle se hi null hai (constructor mein set hua tha)

        list.printList();        // ab output milega: 10, 20, 30, null
    }
}
